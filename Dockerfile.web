FROM golang:1.25-bookworm AS build
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN --mount=type=cache,target=/root/.cache/go-build \
    go build -o /web-server ./cmd/web

FROM debian:bookworm-slim
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates curl sqlite3 && \
    curl -sL https://github.com/microsoft/onnxruntime/releases/download/v1.24.1/onnxruntime-linux-x64-1.24.1.tgz \
    | tar xz -C /opt && \
    apt-get purge -y curl && apt-get autoremove -y && rm -rf /var/lib/apt/lists/*
COPY --from=build /web-server /web-server
WORKDIR /app
ENV ORT_LIB_PATH=/opt/onnxruntime-linux-x64-1.24.1/lib/libonnxruntime.so
ENV LD_LIBRARY_PATH=/opt/onnxruntime-linux-x64-1.24.1/lib
CMD ["/web-server"]
