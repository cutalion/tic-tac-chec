FROM golang:1.25-alpine AS build
RUN apk add --no-cache gcc musl-dev
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=1 go build -o /web-server ./cmd/web

FROM alpine:3.20
RUN apk add --no-cache curl tar && \
    curl -sL https://github.com/microsoft/onnxruntime/releases/download/v1.24.1/onnxruntime-linux-x64-1.24.1.tgz \
    | tar xz -C /opt && \
    apk del curl tar
COPY --from=build /web-server /web-server
WORKDIR /app
ENV ORT_LIB_PATH=/opt/onnxruntime-linux-x64-1.24.1/lib/libonnxruntime.so
ENV LD_LIBRARY_PATH=/opt/onnxruntime-linux-x64-1.24.1/lib
CMD ["/web-server"]
