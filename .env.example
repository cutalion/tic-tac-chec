# PostHog - used by both the frontend analytics SDK and the OTel collector
# (logs ingest at $POSTHOG_HOST/i/v1/logs). POSTHOG_KEY is the project token
# (starts with phc_), found in PostHog -> Project Settings. Do NOT use a
# personal API key (phx_), it won't authenticate logs ingest.
ANALYTICS_ENABLED=false
POSTHOG_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
ALLOWED_ORIGINS=https://ttc.ctln.pw,https://tg.ttc.ctln.pw,https://tic-tac-chec-tg.netlify.app

# Optional: override the asset cache-busting version used by the web app.
# ASSET_VERSION=

# Optional: provide an SSH host key directly instead of using /app/.ssh/host_key.
# HOST_KEY_PEM=

# OpenTelemetry - emitted by the app, fanned out by the collector
DEPLOY_ENV=dev
# OTEL_EXPORTER_OTLP_ENDPOINT is set in docker-compose.yml so the app talks to
# the collector. Override it here if you run the binary outside compose.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Betterstack OTLP logs ingest. Get these from the Betterstack source UI.
BS_INGEST_HOST=https://in-otel.logs.betterstack.com
BS_TOKEN=
